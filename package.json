{
  "name": "info3180-vuejs-flask-starter",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "dev": "node --no-deprecation node_modules/vite/bin/vite.js",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:all": "playwright test -c playwright.config.all-browsers.js",
    "test:all": "vitest && playwright test"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "socket.io-client": "^4.8.3",
    "vue": "^3.2.47",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@vitejs/plugin-vue": "^4.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.27",
    "cypress": "^15.12.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.5.0",
    "happy-dom": "^20.8.4",
    "postcss": "^8.5.8",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "vite": "^4.1.4",
    "vitest": "^4.1.0"
  }
}
