# Render Deployment Environment Variables
# Copy this file to .env on Render or set in dashboard

# Flask Configuration
FLASK_ENV=production
SECRET_KEY=your_strong_secret_key_here_generate_with_secrets_token_hex_32

# Database (Render PostgreSQL)
# This will be automatically set from the database connection string
SQLALCHEMY_DATABASE_URI=postgresql://user:password@host:port/database

# JWT Configuration
JWT_SECRET_KEY=your_jwt_secret_key_here_generate_with_secrets_token_hex_32

# File Uploads
UPLOAD_FOLDER=./uploads
MAX_CONTENT_LENGTH=16777216

# CORS Origins (comma-separated)
CORS_ORIGINS=https://datingapp-frontend.onrender.com,http://localhost:3000

# Mailtrap (Optional - for development emails)
MAILTRAP_SMTP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_SMTP_PORT=2525
MAILTRAP_SMTP_USER=your_mailtrap_user
MAILTRAP_SMTP_PASS=your_mailtrap_password
MAILTRAP_FROM_EMAIL=DriftDater<noreply@driftdater.com>

# Frontend Environment Variables
VITE_API_URL=https://datingapp-backend.onrender.com
VITE_WS_URL=wss://datingapp-backend.onrender.com
