VITE_API_BASE_URL=https://your-backend-service.onrender.com

# Frontend URL for email links
FRONTEND_URL=https://your-frontend-service.onrender.com

# Email Configuration (Production)
# For production, set up a real email SMTP server
# Options: Gmail, SendGrid, Mailgun, etc.
# Example with Gmail:
# MAILTRAP_SMTP_HOST=smtp.gmail.com
# MAILTRAP_SMTP_PORT=587
# MAILTRAP_SMTP_USER=your_email@gmail.com
# MAILTRAP_SMTP_PASS=your_app_password
# MAILTRAP_FROM_EMAIL=DriftDater<noreply@driftdater.com>
