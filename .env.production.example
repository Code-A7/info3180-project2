VITE_API_BASE_URL=https://your-backend-service.onrender.com

# Frontend URL for email links
FRONTEND_URL=https://your-frontend-service.onrender.com

# Email Configuration (Production)
# Render free services can block SMTP ports. Use HTTPS API delivery.
EMAIL_PROVIDER=resend
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM="DriftDater <onboarding@resend.dev>"

# SMTP fallback for hosts that allow SMTP egress:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM_EMAIL="DriftDater <your_email@gmail.com>"
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
