# Flask
SECRET_KEY=your_secret_key_here
DEBUG=True
FLASK_ENV=production

# Database (SQLite for development)
SQLALCHEMY_DATABASE_URI=sqlite:///{PROJECT_DIR}/instance/driftdater.db
SQLALCHEMY_TRACK_MODIFICATIONS=False

# Email via HTTPS API. Recommended for Render free services because SMTP ports
# 25, 465, and 587 can be blocked.
EMAIL_PROVIDER=resend
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM="DriftDater <onboarding@resend.dev>"

# Email via SMTP. Use locally or on hosts that allow SMTP egress.
# Mailtrap sandbox captures messages inside Mailtrap; it does not deliver to the
# recipient's real inbox. Use a real SMTP provider for production delivery.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_EMAIL="DriftDater <your_email@gmail.com>"
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Upload folder
UPLOAD_FOLDER=./uploads
MAX_CONTENT_LENGTH=16777216

# Mailtrap sandbox example for local capture only:
# LOCAL_SMTP_HOST=sandbox.smtp.mailtrap.io
# LOCAL_SMTP_PORT=2525
# LOCAL_SMTP_USER=your_mailtrap_user_here
# LOCAL_SMTP_PASS=your_mailtrap_password_here
# LOCAL_SMTP_FROM_EMAIL="DriftDater <noreply@driftdater.com>"
